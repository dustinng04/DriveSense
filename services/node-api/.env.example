NODE_ENV=development
NODE_PORT=3001
SUPABASE_JWT_SECRET=replace_with_supabase_jwt_secret
# Optional claim checks; defaults to `aud=authenticated`.
# SUPABASE_JWT_ISSUER=http://localhost:54321/auth/v1
# SUPABASE_JWT_AUDIENCE=authenticated
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drivesense
# Database host/port for local API runtime.
# For SQL seeding, run psql against the same target DB.
DB_HOST=localhost
DB_PORT=5432
# DATABASE_URL is optional if POSTGRES_* + DB_HOST/DB_PORT are set.
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
# Optional future Python engine URL. Not used in the extension-first MVP.
# PY_ENGINE_BASE_URL=http://py-engine:8000
# Server-owned Gemini key for limited free trial calls (users without BYOK).
# FREE_CALL_GEMINI_API_KEY=replace_with_server_owned_gemini_key
# Lifetime trial cap per user. Must be an integer between 5 and 10.
# FREE_CALL_TRIAL_LIMIT=10
# Google Drive OAuth client credentials (required for Drive integration routes).
# GOOGLE_DRIVE_CLIENT_ID=replace_with_google_client_id
# GOOGLE_DRIVE_CLIENT_SECRET=replace_with_google_client_secret
# GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost:3001/google-drive/oauth/callback
# Optional redirect after OAuth callback completes.
# GOOGLE_DRIVE_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/settings/integrations
# Notion OAuth client credentials (required for Notion integration routes).
# NOTION_CLIENT_ID=replace_with_notion_client_id
# NOTION_CLIENT_SECRET=replace_with_notion_client_secret
# NOTION_OAUTH_REDIRECT_URI=http://localhost:3001/notion/oauth/callback
# Optional redirect after OAuth callback completes.
# NOTION_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/settings/integrations

