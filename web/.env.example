# Origin of the DriveSense Node API for development proxy.
# Defaults to http://localhost:3001 if not set in vite.config.ts.
VITE_NODE_API_ORIGIN=http://localhost:3001

# Chrome extension ID (see chrome://extensions) — when set, "Save token" on the dashboard pushes the bearer token to the extension via chrome.runtime.sendMessage.
# VITE_DS_EXTENSION_ID=abcdefghijklmnopqrstuvwxyz123456

# Supabase configuration (for future frontend-direct integration).
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
