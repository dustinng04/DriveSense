NODE_ENV=development
NODE_PORT=3001
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drivesense
# Optional future Python engine URL. Not used in the extension-first MVP.
# PY_ENGINE_BASE_URL=http://py-engine:8000
# Server-owned Gemini key for limited free trial calls (users without BYOK).
# Leave empty to disable free-call proxy.
FREE_CALL_GEMINI_API_KEY=
# Lifetime trial cap per user (must be between 5 and 10).
FREE_CALL_TRIAL_LIMIT=10